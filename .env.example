# ----------------------------------------------------------
# check_for_x265.sh – Predefined scan directories
# ----------------------------------------------------------
# Add one SCAN_DIR_<Label>="/path/to/folder" per line.
# The label (with underscores replaced by spaces) appears
# in the interactive menu.
#
# Copy this file to .env and edit the paths to match your setup:
#   cp .env.example .env
# ----------------------------------------------------------
SCAN_DIR_Movies="/mnt/media/movies"
SCAN_DIR_TV_Shows="/mnt/media/tv"
SCAN_DIR_Downloads="/home/user/Downloads"
